              "listen": "test",
              "script": {
                "exec": [
                  "pm.environment.set(\"auth_token\", pm.response.json().accessToken);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"emilys\",\r\n  \"password\": \"emilyspass\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
